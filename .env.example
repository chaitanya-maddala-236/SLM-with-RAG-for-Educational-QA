# ========================
# API KEYS
# ========================
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key
GROQ_API_KEY=your_groq_api_key

# ========================
# DEFAULT MODEL CONFIG
# ========================
# SLM options: phi3, phi3-mini, gemma2, tinyllama, mistral, mistral-7b-instruct
DEFAULT_SLM=mistral-7b-instruct

# Open-source LLM options: llama3-8b, llama3-70b, mixtral-8x7b, qwen2.5-7b, deepseek-llm
DEFAULT_OPEN_MODEL=llama3-8b

# Commercial/API options: gpt-4o, claude-3.5-sonnet, gemini-1.5-pro
DEFAULT_API_MODEL=gpt-4o

# Vision model (LLaVA family via Ollama)
DEFAULT_VISION_MODEL=llava:7b

# ========================
# EMBEDDINGS
# ========================
# Dense text embeddings used by retriever: bge-small, bge-base-en, bge-large, e5-base, etc.
TEXT_EMBEDDING_MODEL=bge-small

# Multimodal embedding backbone: clip | siglip | openclip
MULTIMODAL_EMBEDDING_MODEL=siglip

# ========================
# GENERATION SETTINGS
# ========================
MAX_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.9
REPEAT_PENALTY=1.1

# ========================
# EVALUATION / COST TRACKING
# ========================
TRACK_COST=true
